{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Campaign": {
      "title": "Campaign",
      "description": "Outreach campaign details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Paused", "Draft"] },
        "sequence": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "day": { "type": "number" },
              "subject": { "type": "string" },
              "body": { "type": "string" }
            }
          }
        },
        "stats": {
          "type": "object",
          "properties": {
            "leads": { "type": "number" },
            "sent": { "type": "number" },
            "opened": { "type": "number" },
            "clicked": { "type": "number" },
            "replies": { "type": "number" },
            "conversions": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title"]
    },
    "Lead": {
      "title": "Lead",
      "description": "Information about a potential customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "campaignId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "company": { "type": "string" },
        "website": { "type": "string" },
        "status": { "type": "string", "enum": ["Verified", "Pending", "Invalid"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/campaigns/{campaignId}": {
      "schema": "Campaign",
      "description": "Campaign data"
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Lead data"
    }
  }
}
